<h2>Edit <%= type %> in <%= course.name %></h2>
<form action="/courses/<%= course.id %>/<%= typeLower %>s/<%= item.id %>" method="POST">
  <label for="title">Title:</label>
  <input type="text" id="title" name="title" value="<%= item.title %>" required>
  <button type="submit">Save</button>
</form>
<a href="/courses/<%= course.id %>">Back</a>
